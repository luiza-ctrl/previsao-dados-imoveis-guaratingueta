{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Streamlit (Python module)",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "streamlit",
        "run",
        "${workspaceFolder}/dashboard/app.py"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}